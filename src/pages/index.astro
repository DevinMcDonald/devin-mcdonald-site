---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allEntries = await getCollection('site');
const SECTIONS = allEntries
  .filter(e => e.data.urlPath.length === 1)
  .map(e => ({
    name: e.data.title,
    path: e.data.urlString,
    desc: (e.data.description as string | undefined) ?? '',
  }));

const NOW = new Date();
const dateStr = NOW.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<BaseLayout>
  <main id="terminal-container">
    <div id="output" aria-live="polite"></div>
    <div id="prompt-line" class="hidden">
      <span class="prompt-prefix">
        <span class="pfx-full"><span class="host">you@devin-mcdonald.com:</span>~$&nbsp;</span>
        <span class="pfx-short">~$&nbsp;</span>
      </span>
      <span id="typed-cmd"></span>
      <span id="cursor" class="cursor"></span>
      <span id="ghost"></span>
      <input
        id="cmd-input"
        type="text"
        autocomplete="off"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
        aria-label="terminal input"
      />
    </div>

    <noscript>
      <div class="noscript-nav">
        <p>you@devin-mcdonald.com:~$ ls -al</p>
        {SECTIONS.map(s => (
          <a href={s.path}>dr--r--r-- &nbsp;{s.name}/</a>
        ))}
      </div>
    </noscript>
  </main>
</BaseLayout>

<style>
  #terminal-container {
    height: 100vh;
    height: 100dvh;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    cursor: text;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    #terminal-container { padding: 1rem; }
  }

  #output {
    flex: 1;
    white-space: pre;
    overflow-x: clip;
    overflow-y: auto;
    scrollbar-width: none;
  }

  #output::-webkit-scrollbar { display: none; }

  /* individual output lines */
  :global(.output-line) {
    display: block;
    min-height: 1.6em;
  }

  :global(.ascii-art) {
    color: var(--mauve);
    font-size: clamp(7px, 1.1vw, 13px);
    line-height: 1.25;
    letter-spacing: 0;
  }

  :global(.dim)      { color: var(--overlay0); }
  :global(.green)    { color: var(--green); }
  :global(.blue)     { color: var(--blue); }
  :global(.yellow)   { color: var(--yellow); }
  :global(.mauve)    { color: var(--mauve); }
  :global(.perms)    { color: var(--overlay1); }
  :global(.dir-link) {
    color: var(--blue);
    font-weight: 700;
    cursor: pointer;
    text-decoration: none;
  }
  :global(.dir-link:hover) {
    color: var(--lavender);
    text-decoration: underline;
  }
  :global(.ls-comment) { color: var(--overlay0); }

  :global(.whoami-row) {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    white-space: normal;
    flex-wrap: wrap;
  }
  :global(.whoami-avatar) {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--mauve);
    flex-shrink: 0;
  }

  /* prompt line */
  #prompt-line {
    display: flex;
    align-items: center;
    margin-top: 0.1em;
    position: relative;
  }

  #prompt-line.hidden {
    visibility: hidden;
    pointer-events: none;
  }

  .prompt-prefix {
    color: var(--green);
    flex-shrink: 0;
    white-space: pre;
  }

  :global(.pfx-short) { display: none; }
  /* plain ls */
  :global(.ls-row) { display: flex; align-items: baseline; }
  :global(.ls-row .dir-link) { min-width: 12ch; }
  :global(.ls-comment) { color: var(--overlay0); }

  /* ls -al */
  :global(.ls-al-entry) { display: block; white-space: pre; }
  :global(.perms)       { color: var(--overlay1); }

  @media (max-width: 640px) {
    :global(.pfx-full)   { display: none; }
    :global(.pfx-short)  { display: inline; }
    :global(.ls-comment) { display: none; }
  }

  #typed-cmd {
    color: var(--text);
    white-space: pre;
  }

  .cursor {
    display: inline-block;
    width: 0.55em;
    height: 1.15em;
    background-color: var(--text);
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
    flex-shrink: 0;
  }

  #ghost { color: var(--overlay0); }

  /* hidden real input overlays the visible typed text */
  #cmd-input {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    background: transparent;
    border: none;
    outline: none;
    color: transparent;
    caret-color: transparent;
    font-family: inherit;
    font-size: inherit;
    cursor: text;
  }

  /* noscript fallback */
  .noscript-nav {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .noscript-nav a {
    color: var(--blue);
    font-family: inherit;
  }
</style>

<script define:vars={{ SECTIONS, dateStr }}>
  const sleep = (ms) => new Promise((r) => setTimeout(r, ms));

  const ASCII_TITLE = [
    '██████╗ ███████╗██╗   ██╗██╗███╗   ██╗  ███╗   ███╗ ██████╗██████╗  ██████╗ ███╗   ██╗ █████╗ ██╗     ██████╗ ',
    '██╔══██╗██╔════╝██║   ██║██║████╗  ██║  ████╗ ████║██╔════╝██╔══██╗██╔═══██╗████╗  ██║██╔══██╗██║     ██╔══██╗',
    '██║  ██║█████╗  ██║   ██║██║██╔██╗ ██║  ██╔████╔██║██║     ██║  ██║██║   ██║██╔██╗ ██║███████║██║     ██║  ██║',
    '██║  ██║██╔══╝  ╚██╗ ██╔╝██║██║╚██╗██║  ██║╚██╔╝██║██║     ██║  ██║██║   ██║██║╚██╗██║██╔══██║██║     ██║  ██║',
    '██████╔╝███████╗ ╚████╔╝ ██║██║ ╚████║  ██║ ╚═╝ ██║╚██████╗██████╔╝╚██████╔╝██║ ╚████║██║  ██║███████╗██████╔╝',
    '╚═════╝ ╚══════╝  ╚═══╝  ╚═╝╚═╝  ╚═══╝  ╚═╝     ╚═╝ ╚═════╝╚═════╝  ╚═════╝ ╚═╝  ╚═══╝╚═╝  ╚═╝╚══════╝╚═════╝',
  ];

  const output      = document.getElementById('output');
  const promptLine  = document.getElementById('prompt-line');
  const typedCmd    = document.getElementById('typed-cmd');
  const cursorEl    = document.getElementById('cursor');
  const ghostEl     = document.getElementById('ghost');
  const cmdInput    = document.getElementById('cmd-input');
  const container   = document.getElementById('terminal-container');

  let animationDone = false;
  let currentMatch  = null; // current fuzzy cd match

  function fuzzyMatchSection(query) {
    const q = query.toLowerCase();
    if (!q) return null;
    const prefix = SECTIONS.find(s => s.name.startsWith(q));
    if (prefix) return { section: prefix, ghost: prefix.name.slice(q.length) };
    const sub = SECTIONS.find(s => s.name.includes(q));
    if (sub) return { section: sub, ghost: null };
    const seq = SECTIONS.find(s => {
      let qi = 0;
      for (const ch of s.name) { if (ch === q[qi]) qi++; }
      return qi === q.length;
    });
    return seq ? { section: seq, ghost: null } : null;
  }

  // ── helpers ──────────────────────────────────────────────────────────────

  function appendLine(html = '', cls = '') {
    const el = document.createElement('span');
    el.classList.add('output-line');
    if (cls) el.classList.add(cls);
    el.innerHTML = html;
    output.appendChild(el);
    scrollToBottom();
    return el;
  }

  function scrollToBottom() {
    output.scrollTop = output.scrollHeight;
  }

  function buildPromptHtml(cmd = '') {
    return `<span class="green">` +
      `<span class="pfx-full"><span class="host">you@devin-mcdonald.com:</span>~$</span>` +
      `<span class="pfx-short">~$</span>` +
      `</span>&nbsp;${cmd}`;
  }

  function fitAsciiTitle() {
    document.querySelectorAll('.ascii-art').forEach(el => {
      el.style.fontSize = '';
      const avail = el.parentElement.clientWidth;
      let size = parseFloat(getComputedStyle(el).fontSize);
      while (el.scrollWidth > avail && size > 4) {
        size -= 0.25;
        el.style.fontSize = size + 'px';
      }
    });
  }

  window.addEventListener('resize', fitAsciiTitle);

  function buildWhoamiHtml() {
    return `<span class="whoami-row">` +
      `<img src="/devin.jpg" class="whoami-avatar" alt="devin" />` +
      `<span><span class="mauve">devin</span> — embedded sw engineer / musician / aspiring gorilla</span>` +
      `</span>`;
  }

  function buildLsLine(section) {
    return `<span class="ls-row">` +
      `<a class="dir-link" href="${section.path}">${section.name}/</a>` +
      `<span class="ls-comment">  # ${section.desc}</span>` +
      `</span>`;
  }

  function buildLsLineVerbose(section) {
    return `<span class="ls-al-entry">` +
      `<span class="perms">dr--r--r--</span>  ` +
      `<span class="dim">devin  users  4096  ${dateStr}  </span>` +
      `<a class="dir-link" href="${section.path}">${section.name}/</a>` +
      `<span class="ls-comment">  # ${section.desc}</span>` +
      `</span>`;
  }

  // ── skip handler ──────────────────────────────────────────────────────────

  function skipToEnd() {
    if (animationDone) return;
    animationDone = true;
  }

  container.addEventListener('keydown', skipToEnd, { once: true });
  container.addEventListener('click', skipToEnd, { once: true });

  // ── boot sequence ────────────────────────────────────────────────────────

  async function runBoot() {
    const BAR_LEN = 28;
    const bootEl = appendLine('', 'dim');
    const label = 'Loading ';
    let filled = 0;

    const render = () => {
      const bar = '█'.repeat(filled) + ' '.repeat(BAR_LEN - filled);
      const pct = Math.round((filled / BAR_LEN) * 100);
      bootEl.textContent = `${label}[${bar}] ${pct}%`;
    };

    render();

    for (let i = 0; i <= BAR_LEN; i++) {
      if (animationDone) { filled = BAR_LEN; render(); break; }
      filled = i;
      render();
      await sleep(28);
    }

    bootEl.innerHTML = `<span class="dim">Loading [</span><span class="green">${'█'.repeat(BAR_LEN)}</span><span class="dim">] 100% — done.</span>`;
    await sleep(animationDone ? 0 : 350);
    output.innerHTML = '';
  }

  // ── ascii art ────────────────────────────────────────────────────────────

  function printTitle() {
    for (const line of ASCII_TITLE) appendLine(line, 'ascii-art');
    appendLine();
    fitAsciiTitle();
  }

  async function runAscii() {
    const CHUNK = 5; // chars per tick
    const TICK  = 4; // ms per tick — 6 lines × ~22 ticks × 4ms ≈ 530ms total

    for (const line of ASCII_TITLE) {
      const el = appendLine('', 'ascii-art');
      for (let pos = CHUNK; pos < line.length; pos += CHUNK) {
        if (animationDone) break;
        el.textContent = line.slice(0, pos);
        await sleep(TICK);
      }
      el.textContent = line;
    }
    appendLine();
    fitAsciiTitle();
    await sleep(animationDone ? 0 : 220);
  }

  // ── whoami sequence ──────────────────────────────────────────────────────

  async function runWhoami() {
    const cmd = 'whoami';
    const cmdLine = appendLine(buildPromptHtml(''));
    for (let i = 1; i <= cmd.length; i++) {
      if (animationDone) break;
      cmdLine.innerHTML = buildPromptHtml(cmd.slice(0, i));
      await sleep(60);
    }
    cmdLine.innerHTML = buildPromptHtml(cmd);
    await sleep(animationDone ? 0 : 120);
    appendLine(buildWhoamiHtml());
    appendLine();
    await sleep(animationDone ? 0 : 200);
  }

  // ── ls sequence ──────────────────────────────────────────────────────────

  async function runLs() {
    const verbose = window.innerWidth > 640;
    const cmd = verbose ? 'ls -al' : 'ls';
    const cmdLine = appendLine(buildPromptHtml(''));

    for (let i = 1; i <= cmd.length; i++) {
      if (animationDone) break;
      cmdLine.innerHTML = buildPromptHtml(cmd.slice(0, i));
      await sleep(60);
    }
    cmdLine.innerHTML = buildPromptHtml(cmd);
    await sleep(animationDone ? 0 : 120);

    if (verbose) {
      appendLine(`<span class="dim">total ${SECTIONS.length + 1}</span>`);
      appendLine(`<span class="ls-al-entry"><span class="perms">drwxr-xr-x</span>  <span class="dim">devin  users  4096  ${dateStr}  </span><span class="blue">./</span></span>`);
    } else {
      appendLine('<span class="blue">./</span>');
    }
    await sleep(animationDone ? 0 : 60);

    for (const section of SECTIONS) {
      appendLine(verbose ? buildLsLineVerbose(section) : buildLsLine(section));
      if (!animationDone) await sleep(70);
    }

    appendLine();
    await sleep(animationDone ? 0 : 200);
  }

  // ── instant render (return visits within same session) ──────────────────

  function renderInstant() {
    const verbose = window.innerWidth > 640;
    printTitle();
    appendLine(buildPromptHtml('whoami'));
    appendLine(buildWhoamiHtml());
    appendLine();
    appendLine(buildPromptHtml(verbose ? 'ls -al' : 'ls'));
    if (verbose) {
      appendLine(`<span class="dim">total ${SECTIONS.length + 1}</span>`);
      appendLine(`<span class="ls-al-entry"><span class="perms">drwxr-xr-x</span>  <span class="dim">devin  users  4096  ${dateStr}  </span><span class="blue">./</span></span>`);
      for (const s of SECTIONS) appendLine(buildLsLineVerbose(s));
    } else {
      appendLine('<span class="blue">./</span>');
      for (const s of SECTIONS) appendLine(buildLsLine(s));
    }
    appendLine();
    animationDone = true;
    promptLine.classList.remove('hidden');
    cmdInput.focus();
  }

  // ── main animation ───────────────────────────────────────────────────────

  async function runAnimation() {
    await runBoot();
    await runAscii();
    await runWhoami();
    await runLs();

    animationDone = true;
    sessionStorage.setItem('booted', '1');
    promptLine.classList.remove('hidden');
    cmdInput.focus();
  }

  // ── command handling ─────────────────────────────────────────────────────

  function handleCommand(raw) {
    const cmd = raw.trim();
    appendLine(buildPromptHtml(cmd));

    if (!cmd) return;

    const [verb, ...args] = cmd.split(/\s+/);

    switch (verb.toLowerCase()) {
      case 'ls': {
        const verbose = args[0] === '-al' || args[0] === '-la';
        if (verbose) {
          appendLine(`<span class="dim">total ${SECTIONS.length + 1}</span>`);
          appendLine(`<span class="ls-al-entry"><span class="perms">drwxr-xr-x</span>  <span class="dim">devin  users  4096  ${dateStr}  </span><span class="blue">./</span></span>`);
          for (const s of SECTIONS) appendLine(buildLsLineVerbose(s));
        } else {
          appendLine('<span class="blue">./</span>');
          for (const s of SECTIONS) appendLine(buildLsLine(s));
        }
        break;
      }

      case 'cd': {
        const target = args[0]?.replace(/\/$/, '');
        if (!target || target === '~' || target === '.') break;
        const exact = SECTIONS.find(s => s.name === target || `/${s.name}` === target);
        const dest  = exact ?? currentMatch?.section;
        if (dest) {
          window.location.href = dest.path;
        } else {
          appendLine(`<span class="red">bash: cd: ${target}: No such file or directory</span>`);
        }
        break;
      }

      case 'clear':
        output.innerHTML = '';
        printTitle();
        return;

      case 'reset':
        sessionStorage.removeItem('booted');
        window.location.reload();
        return;

      case 'whoami':
        appendLine(buildWhoamiHtml());
        break;

      case 'help':
        appendLine('<span class="yellow">available commands:</span>');
        appendLine('  <span class="blue">ls</span>          list sections');
        appendLine('  <span class="blue">ls -al</span>      list with details');
        appendLine('  <span class="blue">cd &lt;name&gt;</span>   navigate to a section');
        appendLine('  <span class="blue">whoami</span>      about me');
        appendLine('  <span class="blue">clear</span>       clear terminal, keep title');
        appendLine('  <span class="blue">reset</span>       replay boot animation');
        break;

      default:
        appendLine(`<span class="red">bash: ${verb}: command not found</span>`);
        appendLine(`<span class="dim">type <span class="blue">help</span> for available commands</span>`);
    }

    appendLine();
    scrollToBottom();
  }

  // wire up input
  cmdInput.addEventListener('input', () => {
    const val = cmdInput.value;
    typedCmd.textContent = val;
    cursorEl.style.display = val.length > 0 ? 'none' : 'inline-block';

    const m = val.match(/^cd\s+(.+)$/i);
    if (m) {
      const result = fuzzyMatchSection(m[1]);
      currentMatch = result;
      ghostEl.textContent = result?.ghost ?? '';
    } else {
      currentMatch = null;
      ghostEl.textContent = '';
    }
  });

  cmdInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const val = cmdInput.value;
      cmdInput.value = '';
      typedCmd.textContent = '';
      ghostEl.textContent = '';
      cursorEl.style.display = 'inline-block';
      handleCommand(val);
      currentMatch = null;
    }
  });

  // clicking anywhere on the terminal focuses the input
  container.addEventListener('click', () => {
    if (animationDone) cmdInput.focus();
  });

  // ── go ───────────────────────────────────────────────────────────────────
  if (sessionStorage.getItem('booted')) {
    renderInstant();
  } else {
    runAnimation();
  }
</script>
