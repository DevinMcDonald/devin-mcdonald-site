---
import BaseLayout from './BaseLayout.astro';
import TerminalPrompt from '../components/TerminalPrompt.astro';
import figlet from 'figlet';

interface NoteItem {
  id: string;
  title: string;
  href: string;
}

interface Props {
  title: string;
  section: string;
  sectionPath: string;
  notes?: NoteItem[];
}

const { title, section, sectionPath, notes = [] } = Astro.props;

let titleAscii = '';
try {
  titleAscii = figlet.textSync(title.toUpperCase(), { font: 'ANSI Shadow' }).trimEnd();
} catch {
  titleAscii = title.toUpperCase();
}

const promptPath = `~/${section}/${title.toLowerCase().replace(/\s+/g, '-')}`;
---

<BaseLayout title={`${title} — devin-mcdonald.com`}>
  <div class="note-page">

    <nav class="note-nav">
      <a href={sectionPath} class="green">cd ..</a>
      <span class="dim"> &nbsp;·&nbsp; </span>
      <a href="/" class="green">cd ~</a>
    </nav>

    <header class="note-header">
      <span class="dim">devin@devin-mcdonald.com</span><span class="mauve">:</span><span class="blue">~/{section}</span><span class="mauve">$</span>
      <span class="dim"> cat {title.toLowerCase().replace(/\s+/g, '-')}.md</span>
    </header>

    <div class="note-divider"></div>

    <article class="note-content">
      <pre class="figlet-heading figlet-h1" aria-label={title}>{titleAscii}</pre>
      <slot />
    </article>

    <div class="note-divider"></div>

    <TerminalPrompt promptPath={promptPath} parentHref={sectionPath} notes={notes} />

  </div>
</BaseLayout>

<style>
  .note-page {
    max-width: 90ch;
    margin: 0 auto;
    padding: 2rem;
  }

  .note-nav {
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
  }

  .note-header {
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .note-divider {
    border-top: 1px solid var(--surface1);
    margin: 1rem 0;
  }

  .dim   { color: var(--overlay0); }
  .mauve { color: var(--mauve); }
  .blue  { color: var(--blue); }
  .green { color: var(--green); }
  .green:hover { color: var(--teal); text-decoration: underline; }

  /* ── figlet headings ─────────────────────────────────── */
  :global(.figlet-heading) {
    font-family: inherit;
    line-height: 1.2;
    margin: 2rem 0 1rem;
    overflow-x: clip;
    white-space: pre;
  }

  :global(.figlet-h1) {
    color: var(--mauve);
    font-size: clamp(7px, 1vw, 12px);
    margin-top: 1rem;
  }

  :global(.figlet-h2) {
    color: var(--blue);
    font-size: clamp(8px, 1.1vw, 13px);
  }

  :global(.figlet-h3) {
    color: var(--teal);
    font-size: clamp(9px, 1.2vw, 14px);
  }

  :global(.figlet-h4) {
    color: var(--green);
    font-family: inherit;
    margin: 1rem 0 0.25rem;
  }

  /* ── prose ───────────────────────────────────────────── */
  :global(.note-content p) {
    margin-bottom: 1em;
    line-height: 1.7;
    color: var(--text);
  }

  :global(.note-content a) {
    color: var(--blue);
    text-decoration: none;
  }

  :global(.note-content a:hover) {
    color: var(--lavender);
    text-decoration: underline;
  }

  :global(.note-content ul),
  :global(.note-content ol) {
    margin: 0.5em 0 1em 1.5em;
  }

  :global(.note-content li) {
    margin-bottom: 0.3em;
    line-height: 1.6;
  }

  :global(.note-content strong) { color: var(--text); }
  :global(.note-content em)     { color: var(--subtext1); font-style: italic; }

  :global(.note-content code) {
    background: var(--surface0);
    color: var(--peach);
    padding: 0.1em 0.35em;
    border-radius: 3px;
    font-size: 0.9em;
  }

  :global(.note-content pre:not(.figlet-heading)) {
    background: var(--mantle);
    border: 1px solid var(--surface1);
    padding: 1em;
    overflow-x: auto;
    margin: 1em 0;
  }

  /* ── tables ──────────────────────────────────────────── */
  :global(.note-content table) {
    border-collapse: collapse;
    width: 100%;
    margin: 1em 0;
  }

  :global(.note-content th),
  :global(.note-content td) {
    border: 1px solid var(--surface1);
    padding: 0.4em 0.8em;
    text-align: left;
  }

  :global(.note-content th) {
    color: var(--mauve);
    background: var(--surface0);
  }

  :global(.note-content tr:nth-child(even) td) {
    background: var(--mantle);
  }

  /* ── youtube embeds ──────────────────────────────────── */
  :global(.yt-embed) {
    position: relative;
    width: 100%;
    max-width: 560px;
    margin: 1.5em 0;
    aspect-ratio: 9 / 16;
  }

  :global(.yt-embed iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  function fitFigletHeadings() {
    document.querySelectorAll('.figlet-heading').forEach(el => {
      (el as HTMLElement).style.fontSize = '';
      const parent = (el as HTMLElement).parentElement!;
      let size = parseFloat(getComputedStyle(el).fontSize);
      while (el.scrollWidth > parent.clientWidth && size > 4) {
        size -= 0.25;
        (el as HTMLElement).style.fontSize = size + 'px';
      }
    });
  }

  fitFigletHeadings();
  window.addEventListener('resize', fitFigletHeadings);
</script>
